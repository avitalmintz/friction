{
  "manifest_version": 3,
  "name": "Friction",
  "version": "0.2.0",
  "description": "Adds friction to Instagram: a scroll pause, silent like revocation, and a justification modal before every comment. A refusal of frictionless engagement.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://api.anthropic.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": [
        "src/prompts.js",
        "src/modal.js",
        "src/content.js",
        "src/like-revoke.js",
        "src/comment-justify.js"
      ],
      "css": ["src/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
